#!/bin/sh
set -eu
HOME_DIR="${HOME:-/Users/example}"
LOG_DIR="$HOME_DIR/.codex-overleaf"
mkdir -p "$LOG_DIR" 2>/dev/null || true
{
  printf '%s legacy-launcher.start pid=%s ppid=%s home=%s path=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$$" "${PPID:-}" "$HOME_DIR" "${PATH:-}"
  printf '%s legacy-launcher.node=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "/opt/homebrew/Cellar/node/25.8.1_1/bin/node"
} >> "$LOG_DIR/native-host-launcher.log" 2>/dev/null || true
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"
export CODEX_OVERLEAF_AGENT_CMD="/opt/homebrew/Cellar/node/25.8.1_1/bin/node /Users/example/Desktop/Workfile/2026/RL4REC/codex-overleaf-link/scripts/codex-json-agent.mjs"
exec "/opt/homebrew/Cellar/node/25.8.1_1/bin/node" "/Users/example/Desktop/Workfile/2026/RL4REC/codex-overleaf-link/native-host/src/index.js"
