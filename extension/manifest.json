{
  "manifest_version": 3,
  "name": "Codex Overleaf Link",
  "version": "0.5.0",
  "description": "Connect the active Overleaf project to a local Codex bridge.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "key": "",
  "permissions": [
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "https://www.overleaf.com/project/*",
    "https://overleaf.com/project/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.overleaf.com/project/*",
        "https://overleaf.com/project/*"
      ],
      "js": [
        "src/shared/summary.js",
        "src/shared/agentTranscript.js",
        "src/shared/reviewing.js",
        "src/shared/projectFiles.js",
        "src/shared/undoOperations.js",
        "src/shared/otText.js",
        "src/shared/i18n.js",
        "src/shared/models.js",
        "src/shared/sessionState.js",
        "src/shared/storageKeys.js",
        "src/shared/staleGuard.js",
        "src/shared/storageDb.js",
        "src/shared/storageMigration.js",
        "src/shared/compileAdapter.js",
        "src/shared/compatibility.js",
        "src/content/nativeChannel.js",
        "src/content/writebackController.js",
        "src/content/runController.js",
        "src/content/mirrorHealth.js",
        "src/content/otWarmMirrorController.js",
        "src/contentScript.js"
      ],
      "css": [
        "styles/panel.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icons/codex-overleaf-icon.png",
        "assets/icons/codex-overleaf-dialog-icon.png",
        "src/shared/reviewing.js",
        "src/shared/projectFiles.js",
        "src/shared/staleGuard.js",
        "src/shared/compileAdapter.js",
        "src/shared/otText.js",
        "src/page/overleafCapabilities.js",
        "src/page/compileBridge.js",
        "src/page/overleafEditor.js",
        "src/page/overleafProjectSnapshot.js",
        "src/page/overleafRealtimeObserver.js",
        "src/pageBridge.js"
      ],
      "matches": [
        "https://www.overleaf.com/*",
        "https://overleaf.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Codex Overleaf Link",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_popup": "popup.html"
  }
}
