{
  "manifest_version": 3,
  "name": "Codex Overleaf Link",
  "version": "1.9.7",
  "description": "Connect the active Overleaf project to a local Codex bridge.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "key": "",
  "permissions": [
    "alarms",
    "nativeMessaging",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.overleaf.com/project/*",
    "https://overleaf.com/project/*"
  ],
  "background": {
    "service_worker": "bootstrap/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icons/codex-overleaf-icon.png",
        "assets/icons/codex-overleaf-dialog-icon.png",
        "runtime/src/shared/*",
        "runtime/src/page/*",
        "runtime/src/pageBridge.js"
      ],
      "matches": [
        "https://www.overleaf.com/*",
        "https://overleaf.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Codex Overleaf Link",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_popup": "bootstrap/popup.html"
  }
}
